$(function () {

  const href = window.location.href;
  const path = window.location.pathname;

  let section = null;

  const isContactPage =
    path === "/momentum/get-help/contact-us" ||
    path === "/momentum/get-help/contact-us/";

  /* ----------------------------------------------------
     SECTION detection
  ---------------------------------------------------- */

  if (!isContactPage) {

      section = "Individual"; // default
    
      if (
        href.includes("/momentum/business") ||
        href.includes("/momentum/get-help/contact-us/for-business")
      ) {
        section = "Business";
    
      } else if (
        href.includes("/momentum/corporate") ||
        href.includes("/momentum/get-help/contact-us/for-corporate")
      ) {
        section = "Corporate";
      }
    
  }

  /* ----------------------------------------------------
     TOP NAV active state
  ---------------------------------------------------- */
  $(".navactive-state, .navactive-statePersonal, .navactive-stateBusiness")
    .removeClass("topNavActive");

  const topNavMap = {
    Individual: ".navactive-statePersonal",
    Business: ".navactive-state",
    Corporate: ".navactive-stateBusiness"
  };

  if (section) {
    $(topNavMap[section]).addClass("topNavActive");
  }

  /* ----------------------------------------------------
     SIDE NAV (accordion + active link)
  ---------------------------------------------------- */
  $(".mdc-drawer__accordioncontent")
    .removeClass("open slidedown");

  $(".mdc-drawer__accordionlabel .mdc-expander__indicator")
    .text("expand_more");

  $(".mdc-list-item.nav-link")
    .removeClass("mdc-list-item--activated");

  if (section) {

    const $activeLink = $(
      `.mdc-list-item.nav-link[data-link-type="${section}"]`
    ).first();

    if ($activeLink.length) {

      $activeLink.addClass("mdc-list-item--activated");

      const $accordionContent = $activeLink.closest(
        ".mdc-drawer__accordioncontent"
      );

      $accordionContent.addClass("open slidedown");

      $accordionContent
        .prev(".mdc-drawer__accordionlabel")
        .find(".mdc-expander__indicator")
        .text("expand_less");
    }
  }

  /* ----------------------------------------------------
     CONTACT US routing logic
  ---------------------------------------------------- */
  $("#motion-top-bar-right").on(
    "click",
    'a[href*="/momentum/get-help/contact-us"]',
    function (e) {

      e.preventDefault();
      window.location.href = "/momentum/get-help/contact-us";

    }
  );

});

// Select all elements with the class "mobilePad" inside a "grid" section
const mobilePadElements = document.querySelectorAll('section.grid .mobilePad');

// Iterate over each mobilePad element
mobilePadElements.forEach(mobilePad => {
    // Find the closest parent section with the class "grid"
    const parentSection = mobilePad.closest('section.grid');
    
    // Add the 'force' class to the parent section
    if (parentSection) {
        parentSection.classList.add('mobileZlayoutPad');
    }
});

// Select all spans with the specified class
const spans = document.querySelectorAll('span.mdc-button__icon');

// Loop through each span
spans.forEach(span => {
  // Check if the inner text is 'none'
  if (span.textContent.trim() === 'none') {
    // Remove the entire span element
    span.remove();
  }
});
document.addEventListener("DOMContentLoaded", function() {
    var breadcrumbItems = document.querySelectorAll('#breadcrumb li');

    // Check if there is a second item
    if (breadcrumbItems.length > 2) {
        var secondBreadcrumb = breadcrumbItems[1]; // Get the second breadcrumb item

        // Get the text of the second breadcrumb and convert it to lowercase
        var text = secondBreadcrumb.textContent.toLowerCase();
        
        // Capitalize only the first word
        var capitalizedText = text.charAt(0).toUpperCase() + text.slice(1);

        // Update the second breadcrumb's text with the capitalized version
        secondBreadcrumb.querySelectorAll('.breadcrumb-item a').textContent = capitalizedText;
    }
    
    
});

    function toggleBreadcrumbClass() {
      const breadcrumbs = document.getElementById('motion-breadcrumbs');
      const scrollThreshold = 1; // 1 pixel threshold for when to add/remove cl;asses
      
      if (window.scrollY > scrollThreshold) {
        breadcrumbs.classList.add('mdc-breadcrumbs--fixed-scrolled', 'bt-1-motion-grey--light');
      } else {
        breadcrumbs.classList.remove('mdc-breadcrumbs--fixed-scrolled', 'bt-1-motion-grey--light');
      }
    }


    window.addEventListener('scroll', toggleBreadcrumbClass);
    

$(window).on("scroll", function () {
  const isSmallScreen = window.innerWidth <= 1279; // or use $(window).width() <= 1279
  const hasTabs = $(".mat-tab-header").length > 0;

  if (isSmallScreen && hasTabs) {
    const hasScrolled = $(this).scrollTop() > 190;

    $(".mat-tab-header").toggleClass("tab-scroller", hasScrolled);
    $(".mdc-breadcrumbs--fixed-scrolled").toggleClass("removeshadow", hasScrolled);
  }
});