document.addEventListener("DOMContentLoaded", function() {
    var breadcrumbContainer = document.getElementById("breadcrumb");
    var breadcrumbContainerTwo = document.getElementById("breadcrumbs");

    var navLabel = breadcrumbContainerTwo.getAttribute("data-internal-name");

    var pathArray = window.location.pathname.split("/").filter(function(path) {
        return path.length > 0; 
    });

    var breadcrumbHtml = "";
    var fullPath = "";
    var displayedSegments = 0; 

    var skipSegments = ["personal", "compliance", "campaigns", "get-help", "momentum", "campaign", "support", 
        "business-solutions", "business-continuity", "kimi", "business", "corporate" ];

    var skipPaths = {
        "momentum/personal/will-trust-estate/call-me-back": ["lead"],
        "momentum/personal/car-and-home-insurance/campaign": ["switch"],
        "momentum/personal/car-and-home-insurance/campaign/switch": ["getadvice"],
        "momentum/personal/find-a-financial-adviser/medical-aid-call-me-back": ["medical"],
        "momentum/personal/medical-aid/call-me-back/getadvice": ["medical-aid"],
        "momentum/personal/medical-aid/call-me-back": ["getadvice"],
        "momentum/personal/car-and-home-insurance/find-a-short-term-insurance-adviser":["insure"],
        "momentum/personal/car-and-home-insurance":["insure"],
        "momentum/business/investment-management/local-and-offshore-unit-trusts/request-a-call-back":["getadvice"],
        "momentum/business/investment-management/local-and-offshore-unit-trusts/request-a-call-back/getadvice":["investment-and-savings"],
        "momentum/personal/find-a-financial-adviser/insure-call-me-back":["mi-insure"],
        "momentum/personal/life-insurance/lead/":["lifeinsurance"],
        "momentum/personal/wealth/callmeback/":["getadvice"],
        "momentum/personal/wealth/callmeback/getadvice":["investment-and-savings"],
        "momentum/personal/car-and-home-insurance/car-insurance/":["insure"],
        "momentum/personal/savings/callmeback":["getadvice"],
        "momentum/personal/savings/callmeback/getadvice":["investo"],
        "momentum/about-us": ["about-us"],
        "momentum/personal/products/estate-planning/estate-administration/estate-provider-benefit": ["estate-provider-benefit"],
        "momentum/personal/products/estate-planning/estate-administration": ["estate-administration"],
        "momentum/personal/products/estate-planning": ["estate-planning"],
        "momentum/personal/products": ["products"],
        "investment-management/resource-centre/brochures": ["brochures"],
        "investment-management/resource-centre/fund-facts-and-figures": ["fund-facts-and-figures"],
        //"investment-management/resource-centre/more-information": ["local-information"],
        "investment-management/resource-centre/forms": ["forms"],
        "investment-management/resource-centre/media-centre": ["media-centre"],
        "investment-management/resource-centre/events-and-webinars": ["events-and-webinars"],
        "investment-management/resource-centre/more-information": ["more-information"],
        "investment-management/resource-centre/events-archive": ["events-archive"],
        "investment-management/resource-centre/sponsorships-and-events": ["sponsorships-and-events"],
        "wealth/resource-centre/local-investing": ["local-investing"],
        "wealth/resource-centre/events-and-webinars": ["events-and-webinars"],
        "wealth/resource-centre/offshore-investing": ["offshore-investing"],
        "wealth/resource-centre/more-information": ["more-information"],
        "momentum/personal/savings/resource-centre/legal-and-compliance": ["legal-and-compliance"],
        "momentum/personal/savings/resource-centre/resources-for-individuals": ["resources-for-individuals"],
        "momentum/personal/savings/resource-centre/media-centre": ["media-centre"]
    };

    function shouldSkipSegment(segment, fullPath) {
        if (skipSegments.includes(segment)) return true;
        for (const [parentPath, subSegments] of Object.entries(skipPaths)) {
            if (fullPath.includes(parentPath) && subSegments.includes(segment)) {
                return true;
            }
        }
        return false;
    }

    // **Determine Home URL based on business or personal**
var homeUrl = window.location.pathname.includes("/momentum/business")
    ? "/momentum/business"
    : window.location.pathname.includes("/momentum/corporate")
        ? "/momentum/corporate"
        : "/momentum/personal";
    if (pathArray.length > 2) {
        breadcrumbHtml = `<li class="breadcrumb-item"><a href="${homeUrl}" class="breadcrumb-link" data-content-id='Home'>Home</a></li>`;

        var nonSkippedSegments = pathArray.filter(segment => {
            fullPath += "/" + segment;
            return !shouldSkipSegment(segment, fullPath);
        }).length;

        if (nonSkippedSegments > 2) {
            breadcrumbHtml += `<li class="breadcrumb-item breadcrumb-link" data-content-id='...'>...</li>`;
        }

        fullPath = ""; 
        pathArray.forEach(function(segment, index) {
            fullPath += "/" + segment;
            if (shouldSkipSegment(segment, fullPath)) return;

            displayedSegments++;

            if (displayedSegments > nonSkippedSegments - 2) {
                var formattedSegment = segment.replace(/-/g, " ").toLowerCase();
                formattedSegment = formattedSegment.charAt(0).toUpperCase() + formattedSegment.slice(1);

                if (index === pathArray.length - 1) {
                    breadcrumbHtml += `<li class="breadcrumb-item active" aria-current="page"><a href="${fullPath}" class="breadcrumb-link" data-content-id='${navLabel}'>${navLabel}</a></li>`;
                } else {
                    breadcrumbHtml += `<li class="breadcrumb-item"><a href="${fullPath}" class="breadcrumb-link" data-content-id='${formattedSegment}'>${formattedSegment}</a></li>`;
                }
            }
        });
    } else {
        breadcrumbHtml = `<li class="breadcrumb-item"><a href="${homeUrl}" class="breadcrumb-link" data-content-id='Home'>Home</a></li>`;
        pathArray.forEach(function(segment, index) {
            fullPath += "/" + segment;
            if (shouldSkipSegment(segment, fullPath)) return;

            var formattedSegment = segment.replace(/-/g, " ").toLowerCase();
            formattedSegment = formattedSegment.charAt(0).toUpperCase() + formattedSegment.slice(1);

            if (index === pathArray.length - 1) {
                breadcrumbHtml += `<li class="breadcrumb-item active" aria-current="page"><a href="${fullPath}" class="breadcrumb-link" data-content-id='${navLabel}'>${navLabel}</a></li>`;
            } else {
                breadcrumbHtml += `<li class="breadcrumb-item"><a href="${fullPath}" class="breadcrumb-link" data-content-id='${formattedSegment}'>${formattedSegment}</a></li>`;
            }
        });
    }

    breadcrumbContainer.innerHTML = breadcrumbHtml;

});

  
